# Files in the repo root that must NOT be served as public static assets.
# Cloudflare uploads everything in [assets].directory ("./") unless ignored here.
# (Uses .gitignore-style patterns.)

# version control + tooling
.git
.gitignore
.assetsignore
.wrangler

# internal project knowledge base / scratch (never public)
_context
_files
_archive

# repo docs + deploy config (not web assets)
*.md
wrangler.toml
worker.js

# build tooling (the per-number page generator) — never served
*.py

# internal reference copy of the IndexNow key
# (the real verification file 7ca1a2e6...txt IS served, on purpose)
indexnow-key.txt
